# API base URL — versioned (no trailing slash)
VITE_API_URL=https://perfectelt.com/perfect/v1

# WebSocket URL — native WebSocket endpoint (Spring SockJS /websocket sub-path)
# The code auto-converts https:// → wss:// and http:// → ws://
# so you can use either scheme here.
VITE_WS_URL=https://perfectelt.com/perfect/v1/ws/websocket

# Station identifier shown in scan queue logs
VITE_STATION_ID=STATION-01
