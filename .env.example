# Full versioned API path
VITE_API_URL=https://perfectelt.com/perfect/v1

# WebSocket endpoint
VITE_WS_URL=https://perfectelt.com/perfect/v1/ws

# Default station identifier for this scanner device
VITE_STATION_ID=STATION-01
